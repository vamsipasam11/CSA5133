import math

def rsa_algorithm():
    # 1. User Input for Keys
    print("--- RSA Key Generation ---")
    p = int(input("Enter prime number p: "))
    q = int(input("Enter prime number q: "))
    e = int(input("Enter public exponent e: "))

    # 2. Mathematical Setup
    n = p * q
    phi = (p - 1) * (q - 1)

    # Check if e is valid
    if math.gcd(e, phi) != 1:
        print("Error: e and phi(n) are not coprime. Choose a different e.")
        return

    # 3. Calculate Private Key d
    # pow(base, exp, mod) where exp = -1 finds the modular inverse
    try:
        d = pow(e, -1, phi)
    except ValueError:
        print("Error: Modular inverse does not exist.")
        return

    print(f"\nPublic Key: (e={e}, n={n})")
    print(f"Private Key: (d={d}, n={n})")
    print("-" * 25)

    # 4. User Input for Message
    msg = int(input("\nEnter numeric message to encrypt (M < n): "))

    # 5. Encryption
    ct = pow(msg, e, n)
    print(f"Encrypted Ciphertext: {ct}")

    # 6. Decryption
    pt = pow(ct, d, n)
    print(f"Decrypted Plaintext: {pt}")

# Run the program
rsa_algorithm()
