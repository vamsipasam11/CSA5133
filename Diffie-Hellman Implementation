def diffie_hellman():
    
    P = int(input("Enter a prime number P: "))
    G = int(input("Enter a generator G: "))


    a = int(input("Enter A private key a: "))
    x = pow(G, a, P) 
    print(f"A Public Key x: {x}")

  
    b = int(input("Enter B private key b: "))
    y = pow(G, b, P) 
    print(f"B Public Key y: {y}")

  
    ka = pow(y, a, P) 
    kb = pow(x, b, P) 

    print(f"\nShared Secret Key of A: {ka}")
    print(f"Shared Secret Key of B: {kb}")

    if ka == kb:
        print("Success! Both parties have the same shared secret.")
    else:
        print("Error: Keys do not match.")

diffie_hellman()
